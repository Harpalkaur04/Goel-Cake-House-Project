# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/goel-cake-house
# For production: mongodb+srv://username:password@cluster.mongodb.net/goel-cake-house

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Admin Credentials (for initial setup)
ADMIN_EMAIL=admin@goelcakehouse.com
ADMIN_PASSWORD=Admin@12345

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# WhatsApp (Business number)
WHATSAPP_NUMBER=919592285145
